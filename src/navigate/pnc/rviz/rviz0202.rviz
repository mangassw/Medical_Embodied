Panels:
  - Class: rviz/Displays
    Help Height: 138
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /Grid1
        - /TF1/Frames1
      Splitter Ratio: 0.5
    Tree Height: 1064
  - Class: rviz/Selection
