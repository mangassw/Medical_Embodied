<launch>
  
  <!-- 参数 -->
  <arg name="cmd_vel_topic" default="/cmd_vel" />
  <arg name="odom_topic" default="/odom_diff" />
  <arg name="map2d" default="/home/wu/robo_ws/xj_robot0128/PCD/scans.yaml" />
  <arg name="map3d" default="/home/wu/robo_ws/xj_robot0128/PCD/scans.pcd" />
  <arg name="use_localization" default="true" />
  <arg name="use_simu" default="true" />
  <arg name="localization_rviz" default="false"/>
  <arg name="pnc_rviz" default="true"/>
  <arg name="use_goal_bridge" default="true"/>
  <arg name="vel_plotter" default="true"/>
  <!-- 仿真参数 -->
  <arg name="x_pos" default="0.0"/>
  <arg name="y_pos" default="0.0"/>
  <arg name="z_pos" default="0.07"/>
  <arg name="gui" default="true"/>
  <arg name="simu_rviz" default="false"/>
 
  <!-- 仿真 -->
  <group if="$(arg use_simu)">
    <include file="$(find xjrobot_simu)/launch/simu.launch">
      <arg name="x_pos" value="$(arg x_pos)" />
      <arg name="y_pos" value="$(arg y_pos)" />
      <arg name="z_pos" value="$(arg z_pos)" />
      <arg name="gui" value="$(arg gui)" />
      <arg name="simu_rviz" value="$(arg simu_rviz)" />
    </include>
  </group>

  <!-- 定位 -->
  <group if="$(arg use_localization)">
    <include file="$(find xjrobot_loc)/launch/loc.launch">
      <arg name="map2d" value="$(arg map2d)" />
      <arg name="map3d" value="$(arg map3d)" />
      <arg name="loc_rviz" value="$(arg localization_rviz)" />
    </include>
  </group>

  <!-- MBF + MPPI -->
  <node pkg="mbf_costmap_nav" type="mbf_costmap_nav" respawn="false" name="move_base_flex" output="screen">
    <rosparam file="$(find xjrobot_pnc)/config/mppi/costmap_params.yaml" command="load" />
    <rosparam file="$(find xjrobot_pnc)/config/mppi/move_base_flex_mppi.yaml" command="load" />
    <rosparam file="$(find xjrobot_pnc)/config/mppi/recovery_behavior_params.yaml" command="load" />
    <rosparam file="$(find xjrobot_pnc)/config/mppi/mppi_controller_ros.yaml" command="load" />
    <rosparam file="$(find xjrobot_pnc)/config/mppi/costmap_converter_params.yaml" command="load" />
    <remap from="cmd_vel" to="$(arg cmd_vel_topic)"/>
    <remap from="odom" to="$(arg odom_topic)"/>
  </node>

  <!-- 让 RViz 的 /move_base_simple/goal 生效 -->
  <group if="$(arg use_goal_bridge)">
    <node pkg="xjrobot_pnc" type="xjrobot_mbf_bridge" respawn="false" name="xjrobot_mbf_bridge" />
  </group>

  <group if="$(arg vel_plotter)">
    <node pkg="xjrobot_pnc" type="vel_plotter.py" name="vel_plotter" output="screen">
      <param name="cmd_topic" value="$(arg cmd_vel_topic)" />
      <param name="odom_topic" value="$(arg odom_topic)" />
      <param name="use_odom" value="true" />
      <param name="window" value="15.0" />
      <param name="sample_hz" value="20.0" />
    </node>
  </group>

  <!-- 可视化 -->
  <group if="$(arg pnc_rviz)">
    <node pkg="rviz" type="rviz" name="rviz" args="-d $(find xjrobot_pnc)/rviz/rviz0202.rviz" />
  </group>
</launch>
